ARCH 			= riscv64
ARCHDIR 		= arch/$(ARCH)
CROSS			= riscv64-unknown-elf-

CC      		= $(CROSS)gcc
LD      		= $(CROSS)ld
OBJCOPY 		= $(CROSS)objcopy

BUILD			= build/$(ARCH)
CFLAGS  		= -O3 -ffreestanding -nostdlib -Iinclude/arch/$(ARCH) -Iinclude -Wall -Wextra -fPIC # -Werror
LDFLAGS 		= -T $(ARCHDIR)/linker.ld

TARGET			= $(BUILD)/kernel.elf

KERNEL_C_SRCS 	:= $(shell find kernel -name "*.c" | grep -v kernel/drivers/uart.c)
PLATFORM_C_SRCS := $(shell find platform -name "*.c")
LIB_C_SRCS		:= $(shell find lib -name "*.c")
ARCH_C_SRCS 	:= $(shell find $(ARCHDIR) -name "*.c")
ARCH_S_SRCS		:= $(shell find $(ARCHDIR) -name "*.S")

ALL_C_SRCS 		:= $(KERNEL_C_SRCS) $(PLATFORM_C_SRCS) $(ARCH_C_SRCS) $(LIB_C_SRCS)

OBJS 			:= $(patsubst %.c,$(BUILD)/%.o,$(ALL_C_SRCS))
OBJS 			+= $(patsubst %.S,$(BUILD)/%.o,$(ARCH_S_SRCS))

all: $(TARGET)

$(BUILD):
	mkdir -p $(BUILD)

# Compile C
$(BUILD)/%.o: %.c
	@mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

# Compile ASM
$(BUILD)/%.o: %.S | $(BUILD)
	@mkdir -p $(dir $@)
	$(CC) -c $< -o $@

LIBGCC 			= $(shell $(CC) -print-libgcc-file-name)

# Link
$(TARGET): $(OBJS)
	$(LD) $(LDFLAGS) $(OBJS) $(LIBGCC) -o $@

run: all
	qemu-system-riscv64 \
		-machine virt \
		-bios default \
		-m 1024 \
		-kernel $(TARGET) \
		-nographic

clean:
	rm -rf $(BUILD)
